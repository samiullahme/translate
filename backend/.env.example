# FastAPI Backend Environment Configurations
# Required for proxying OCR, Translation, and Voice synthesis requests

# Port and server setup
PORT=8000
HOST=0.0.0.0

# Supabase Settings (used for validating JWT bearer tokens)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-placeholder

# OpenAI-Compatible Base URL and API Model (used for Translate, Summarize, Chat)
OPENAI_API_KEY=your-openai-api-key-placeholder
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# OCR Provider: 'google' (Google Cloud Vision), 'textract' (AWS Textract), or 'mistral'
OCR_PROVIDER=google
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-credentials.json

# Cartesia Settings (used for high-fidelity TTS speech synthesis with word timestamps)
CARTESIA_API_KEY=your-cartesia-api-key-placeholder
CARTESIA_VERSION=2024-06-10
CARTESIA_VOICE_ID=your-cartesia-voice-id
CARTESIA_MODEL=sonic-english

# Whisper STT Settings (used for audio voice chat transcription)
WHISPER_API_KEY=your-whisper-api-key-placeholder
