# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Supabase Configurations
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-placeholder

# FastAPI Backend URL for proxying AI requests
# - Emulator:     http://10.0.2.2:8000
# - Phone on LAN: http://YOUR_PC_LAN_IP:8000  (debug build only; needs cleartext allowance)
# - Recommended:  https://api.yourdomain.com   (HTTPS via Cloudflare Tunnel — works everywhere)
BACKEND_URL=http://10.0.2.2:8000
